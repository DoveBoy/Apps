{
    "version": "2.14.0",
    "description": "免费、极简、轻量且高性能的C盘清理工具",
    "homepage": "https://github.com/Chunyu33/light-c",
    "license": {
        "identifier": "Copyright (c) 2026 Evan Lau.",
        "url": "https://github.com/Chunyu33/light-c?tab=License-1-ov-file#License-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Chunyu33/light-c/releases/download/v2.14.0/LightC_2.14.0_x64-setup.exe#/dl.7z",
            "hash": "89c14d461110e74b9d8595d5b23259808da8b75733d516d88649a82d4a17db50",
            "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninst*\" -Force -Recurse"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:LOCALAPPDATA\\com.chunyu.LightC\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\com.chunyu.LightC\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "LightC.exe",
    "shortcuts": [
        [
            "LightC.exe",
            "LightC"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/Chunyu33/light-c/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Chunyu33/light-c/releases/download/v$version/LightC_$version_x64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.json"
        }
    }
}
