{
    "version": "3.1.3",
    "description": "「彩读 3.0 书源 × AI+」——一款会给内容上色的本地 TXT 小说阅读器，带给你不一样的阅读体验！（也支持打开常见的电子书格式，如 .epub）。还有章节识别、简繁互转、划线标注、记笔记、多角色语音朗读、AI 阅读助手、书源找书等功能。支持 macOS、Windows 和 Linux。",
    "homepage": "https://github.com/ssnangua/ColorTxt",
    "license": {
        "identifier": "MPL-2.0 license",
        "url": "https://github.com/ssnangua/ColorTxt#MPL-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ssnangua/ColorTxt/releases/download/v3.1.3/colortxt-3.1.3-Setup.exe#/dl.7z",
            "hash": "sha512:ff96eab8c3bd12e27f5e7a9c55d72efe5f341b619bfaba4b6619fcfb31981467652e9005e3f595abc8281900645690c1d1c3c8f3337d522f3100980c4f2b3b63",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse",
                "Get-ChildItem \"$dir\\彩读*.exe\" | Rename-Item -NewName 'ColorTxt.exe'"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\colortxt\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\colortxt\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "ColorTxt.exe",
    "shortcuts": [
        [
            "ColorTxt.exe",
            "ColorTxt"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/ssnangua/ColorTxt/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ssnangua/ColorTxt/releases/download/v$version/colortxt-$version-Setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "mode": "extract",
            "regex": "(?sm)$basename.*?sha512:\\s+$base64"
        }
    }
}
