            },
            "32bit": {
                "url": "https://github.com/jgraph/drawio-desktop/releases/download/v$version/draw.io-ia32-$version-windows-32bit-installer.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/Files-SHA256-Hashes.txt",
            "regex": "$basename\\s*?$sha256"
        }
    }
